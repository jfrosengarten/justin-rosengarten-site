---
import "../styles/global.css";

const {
  title = "Justin Rosengarten",
  description = "Personal site for Justin Rosengarten.",
  canonical = "https://justinrosengarten.com/",
  ogImage,
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />

    <meta name="twitter:card" content="summary_large_image" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <link rel="stylesheet" href="https://use.typekit.net/zto4gpp.css" />
  </head>

  <body>
    <!-- Desktop header -->
    <header class="site-header">
      <div class="header-col identity-col">
        <a href="/" class="home-name">Justin Rosengarten</a>
        <div class="identity-info">
          <a href="mailto:justin.rosengarten@gmail.com" class="contact-group">
            <span class="contact-label">Contact</span>
            <span class="home-email">justin.rosengarten@gmail.com</span>
          </a>
          <span class="home-location">New York, NY</span>
          <div class="home-social">
            <a href="https://www.instagram.com/justinrosengarten/" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="Instagram">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                <circle cx="12" cy="12" r="4"/>
                <circle cx="17.5" cy="6.5" r="0.5" fill="currentColor" stroke="none"/>
              </svg>
            </a>
            <a href="https://www.linkedin.com/in/justin-rosengarten/" target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="LinkedIn">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
      <a href="/social" class="header-col nav-link">Social</a>
      <a href="/branded" class="header-col nav-link">Branded</a>
      <a href="/documentary" class="header-col nav-link">Documentary</a>
      <a href="/about" class="header-col nav-link">About</a>
    </header>

    <!-- Mobile header -->
    <div class="mobile-header">
      <button class="menu-toggle" aria-expanded="false" aria-label="Toggle menu">
        <span class="menu-text">Menu</span>
        <span class="menu-icon">+</span>
      </button>
      <nav class="mobile-menu" aria-hidden="true">
        <a href="/" class="mobile-menu-item">Home</a>
        <a href="/social" class="mobile-menu-item">Social</a>
        <a href="/branded" class="mobile-menu-item">Branded</a>
        <a href="/documentary" class="mobile-menu-item">Documentary</a>
        <a href="/about" class="mobile-menu-item">About</a>
      </nav>
    </div>

    <!-- Scroll-driven hero section -->
    <div class="hero-about" id="heroAbout" aria-hidden="true">
      <a href="/" class="hero-name" id="heroName">Justin Rosengarten</a>
      <p class="hero-bio">
        Documentary editor and director based in New York. I work with filmmakers and brands to build stories that feel true — in documentary, advertising, and everything in between.
      </p>
    </div>

    <slot />
  </body>
</html>

<script>
  // Scroll-driven animation
  const headerCols = document.querySelectorAll<HTMLElement>('.header-col');
  const heroAbout  = document.getElementById('heroAbout')!;
  const heroName   = document.getElementById('heroName')!;
  const heroBio    = heroAbout.querySelector<HTMLElement>('.hero-bio')!;

  const SCROLL_START = 60;
  const SCROLL_END   = 650;

  let currentP = 0;
  let targetP  = 0;
  let rafId    = 0;

  function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }
  function clamp01(v: number) { return Math.min(1, Math.max(0, v)); }
  function ease(t: number) { return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t; }

  function applyFrame(p: number) {
    const ep = ease(p);

    // Header columns fade up
    headerCols.forEach(col => {
      col.style.opacity   = String(clamp01(1 - p * 1.4));
      col.style.transform = `translateY(${-ep * 16}px)`;
    });

    // Hero name: rotate clockwise -90 → 0, settle into position
    heroName.style.opacity   = String(clamp01(p * 1.8));
    heroName.style.transform = `translateY(${lerp(200, 80, ep)}px) rotate(${lerp(-90, 0, ep)}deg)`;
    heroAbout.style.pointerEvents = p > 0.92 ? 'auto' : 'none';

    // Bio fades in after name is nearly horizontal
    const bioP = clamp01((ep - 0.7) / 0.3);
    heroBio.style.opacity   = String(bioP);
    heroBio.style.transform = `translateY(${lerp(14, 0, bioP)}px)`;
  }

  function tick() {
    currentP += (targetP - currentP) * 0.07;
    applyFrame(currentP);
    if (Math.abs(targetP - currentP) > 0.0005) {
      rafId = requestAnimationFrame(tick);
    }
  }

  window.addEventListener('scroll', () => {
    targetP = clamp01((window.scrollY - SCROLL_START) / (SCROLL_END - SCROLL_START));
    cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(tick);
  }, { passive: true });

  applyFrame(0);

  // Match bio width to rendered name width
  function syncBioWidth() {
    heroBio.style.width = heroName.offsetWidth + 'px';
  }
  syncBioWidth();
  window.addEventListener('resize', syncBioWidth);
</script>

<script>
  const toggle = document.querySelector('.menu-toggle') as HTMLButtonElement;
  const menu = document.querySelector('.mobile-menu') as HTMLElement;
  const icon = document.querySelector('.menu-icon') as HTMLElement;

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));
    menu.setAttribute('aria-hidden', String(isOpen));
    icon.textContent = isOpen ? '+' : '–';
    menu.classList.toggle('is-open', !isOpen);
  });
</script>

<style>
  /* ── SHARED ── */
  .mobile-header { display: none; }
  .mobile-menu   { display: none; }

  .mobile-menu.is-open {
    display: flex;
    flex-direction: column;
  }

  /* ── DESKTOP (769px+) ── */
  @media (min-width: 769px) {
    .site-header {
      position: fixed;
      top: 20px;
      left: 0;
      right: 0;
      display: flex;
      gap: 10px;
      padding: 0 32px;
      z-index: 100;
    }

    .header-col {
      flex: 1;
      border-top: 1px solid rgba(255, 255, 255, 0.5);
      padding: 8px 0 20px 0;
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .identity-col {
      flex: 1;
      flex-direction: row;
      align-items: flex-start;
      gap: 10px;
    }

    .home-name {
      font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-weight: 800;
      font-size: 14px;
      letter-spacing: 0.12em;
      color: rgba(255, 255, 255, 0.92);
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      white-space: nowrap;
      align-self: stretch;
      transition: opacity 150ms ease;
    }

    .home-name:hover { opacity: 0.65; }


    .identity-info {
      display: flex;
      flex-direction: column;
      gap: 4px;
      padding-top: 2px;
    }

    .contact-group {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .contact-label {
      font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 0.01em;
      color: rgba(255, 255, 255, 0.55);
      transition: color 150ms ease;
    }

    .contact-group:hover .contact-label {
      color: rgba(255, 255, 255, 0.92);
    }

    .contact-group:hover .home-email {
      color: rgba(255, 220, 80, 0.85);
    }

    .home-email,
    .home-location {
      font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: 11px;
      font-weight: 400;
      letter-spacing: 0.01em;
    }

    .home-email    { color: rgba(255, 255, 255, 0.45); transition: color 150ms ease; }
    .home-location { color: rgba(255, 255, 255, 0.35); }

    .home-social {
      display: flex;
      gap: 10px;
      margin-top: 2px;
    }

    .social-icon {
      color: rgba(255, 255, 255, 0.4);
      display: flex;
      align-items: center;
      transition: color 150ms ease;
    }

    .social-icon:hover { color: rgba(255, 255, 255, 0.85); }

    .nav-link {
      font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: 13px;
      font-weight: 400;
      letter-spacing: 0.01em;
      color: rgba(255, 255, 255, 0.55);
      transition: color 150ms ease;
    }

    .nav-link:hover,
    .nav-link.active { color: rgba(255, 255, 255, 0.92); }
  }

  /* ── HERO SCROLL SECTION ── */
  .hero-about {
    position: fixed;
    top: 0;
    left: 80px;
    right: 80px;
    z-index: 40;
    pointer-events: none;
  }

  .hero-name {
    position: absolute;
    top: 0;
    left: 0;
    display: block;
    font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
    font-weight: 800;
    font-size: clamp(32px, 5vw, 64px);
    letter-spacing: -0.02em;
    color: rgba(255, 255, 255, 0.92);
    white-space: nowrap;
    transform-origin: left center;
    will-change: transform, opacity;
    opacity: 0;
  }

  .hero-bio {
    position: absolute;
    top: 175px;
    left: 0;
    font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
    font-size: 15px;
    font-weight: 300;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.6);
    text-align: justify;
    opacity: 0;
    will-change: transform, opacity;
  }

  /* ── MOBILE (≤768px) ── */
  @media (max-width: 768px) {
    .site-header { display: none; }

    .mobile-header {
      display: block;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
    }

    .menu-toggle {
      display: flex;
      align-items: center;
      gap: 6px;
      background: none;
      border: none;
      border-top: 1px solid rgba(255, 255, 255, 0.5);
      padding: 16px 20px;
      cursor: pointer;
      width: 100%;
      text-align: left;
    }

    .menu-text {
      font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: 14px;
      font-weight: 400;
      color: rgba(255, 255, 255, 0.75);
      letter-spacing: 0.03em;
    }

    .menu-icon {
      font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: 18px;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.75);
      line-height: 1;
    }

    .mobile-menu-item {
      font-family: ui-sans-serif, system-ui, -apple-system, sans-serif;
      font-size: 15px;
      font-weight: 300;
      color: rgba(255, 255, 255, 0.75);
      letter-spacing: 0.03em;
      padding: 16px 20px;
      position: relative;
      transition: color 150ms ease;
    }

    .mobile-menu-item::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 20px;
      right: 20px;
      height: 2px;
      background: rgba(255, 255, 255, 0.5);
    }

    .mobile-menu-item:hover { color: rgba(255, 255, 255, 0.92); }

    .mobile-menu {
      background: transparent;
    }
  }
</style>
